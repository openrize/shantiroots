{
  "rewrites": [
    { "source": "/shop", "destination": "/shop.html" },
    { "source": "/shop.html", "destination": "/shop.html" },
    { "source": "/about", "destination": "/about.html" },
    { "source": "/about.html", "destination": "/about.html" },
    { "source": "/contact", "destination": "/contact.html" },
    { "source": "/contact.html", "destination": "/contact.html" },
    { "source": "/blog", "destination": "/blog.html" },
    { "source": "/blog.html", "destination": "/blog.html" },
    { "source": "/checkout", "destination": "/checkout.html" },
    { "source": "/checkout.html", "destination": "/checkout.html" },
    { "source": "/faq", "destination": "/faq.html" },
    { "source": "/faq.html", "destination": "/faq.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/privacy.html", "destination": "/privacy.html" },
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/terms.html", "destination": "/terms.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
